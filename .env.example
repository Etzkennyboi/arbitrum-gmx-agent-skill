# ============================================================
# arbitrum-gmx-agent-skill — Environment Variables
# ============================================================

# Arbitrum wallet for agent operations (REQUIRED)
AGENT_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Arbitrum RPC (optional overrides — defaults are public endpoints)
ARBITRUM_ONE_RPC=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Auto-populated after running: npm run register
AGENT_ID=

# Public URL of this agent (for registry endpoint field)
AGENT_ENDPOINT=https://your-deployment.railway.app

# Server port
PORT=3000
